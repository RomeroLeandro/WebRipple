---
---
<nav class="nav">
  <div class="nav-inner">
    <a href="#inicio" class="nav-logo">
      <!-- Logo SVG inline basado en el logo WebRipple -->
      <svg width="36" height="28" viewBox="0 0 36 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M2 4L10 22L18 8L26 22L34 4" stroke="url(#wgrad)" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>
        <defs>
          <linearGradient id="wgrad" x1="2" y1="4" x2="34" y2="22" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#0d1b3e"/>
            <stop offset="100%" stop-color="#29c6e0"/>
          </linearGradient>
        </defs>
      </svg>
      <span class="logo-text">WebRipple</span>
    </a>
    <ul class="nav-links">
      <li><a href="#servicios">Servicios</a></li>
      <li><a href="#portfolio">Portfolio</a></li>
      <li><a href="#precios">Precios</a></li>
      <li><a href="#contacto">Contacto</a></li>
    </ul>
    <a href="#precios" class="nav-cta">Ver planes</a>
    <button class="nav-hamburger" id="hamburger" aria-label="Menú">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="nav-mobile" id="mobileMenu">
    <a href="#servicios" class="mob-link">Servicios</a>
    <a href="#portfolio" class="mob-link">Portfolio</a>
    <a href="#precios" class="mob-link">Precios</a>
    <a href="#contacto" class="mob-link">Contacto</a>
    <a href="#precios" class="mob-cta">Ver planes</a>
  </div>
</nav>

<style>
.nav {
  position: fixed; top: 0; left: 0; right: 0;
  z-index: 100;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
}
.nav-inner {
  max-width: 1200px; margin: 0 auto;
  display: flex; align-items: center;
  padding: 16px 32px;
  gap: 32px;
}
.nav-logo {
  display: flex; align-items: center; gap: 10px;
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-weight: 700; font-size: 1.25rem;
  color: var(--navy);
}
.logo-text { letter-spacing: -0.02em; }
.nav-links {
  display: flex; list-style: none; gap: 8px; margin-left: auto;
}
.nav-links a {
  padding: 8px 14px;
  font-size: 0.875rem; font-weight: 500;
  color: var(--muted);
  border-radius: 8px;
  transition: color 0.2s, background 0.2s;
}
.nav-links a:hover { color: var(--blue); background: var(--off); }
.nav-cta {
  background: var(--grad);
  color: white !important;
  padding: 10px 22px;
  border-radius: 10px;
  font-size: 0.875rem;
  font-weight: 600;
  white-space: nowrap;
  transition: opacity 0.2s, transform 0.2s;
}
.nav-cta:hover { opacity: 0.9; transform: translateY(-1px); }
.nav-hamburger {
  display: none;
  flex-direction: column; gap: 5px;
  background: none; border: none; cursor: pointer;
  padding: 6px; margin-left: auto;
}
.nav-hamburger span {
  display: block; width: 22px; height: 2px;
  background: var(--navy); border-radius: 2px;
  transition: all 0.3s;
}
.nav-mobile {
  display: none;
  flex-direction: column;
  padding: 16px 32px 24px;
  border-top: 1px solid var(--border);
  gap: 4px;
}
.nav-mobile.open { display: flex; }
.mob-link {
  padding: 12px 16px;
  font-size: 0.95rem; font-weight: 500;
  color: var(--muted); border-radius: 8px;
  transition: background 0.2s;
}
.mob-link:hover { background: var(--off); color: var(--blue); }
.mob-cta {
  margin-top: 8px;
  background: var(--grad);
  color: white;
  padding: 14px 16px;
  border-radius: 10px;
  font-size: 0.95rem;
  font-weight: 600;
  text-align: center;
}
@media (max-width: 768px) {
  .nav-links, .nav-cta { display: none; }
  .nav-hamburger { display: flex; }
}
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const menu = document.getElementById('mobileMenu');
  hamburger?.addEventListener('click', () => menu?.classList.toggle('open'));
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu.classList.remove('open')));
</script>
