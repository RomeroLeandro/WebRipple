      <div class="hero-actions">
        <a href="#precios" class="btn-primary">
          Ver planes y precios
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="https://wa.me/5491112345678?text=Hola!%20Me%20interesa%20una%20web%20para%20mi%20negocio" target="_blank" class="btn-ghost">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.136.558 4.14 1.535 5.878L.057 23.5l5.763-1.513A11.943 11.943 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.894a9.893 9.893 0 01-5.032-1.378l-.361-.214-3.741.981.999-3.648-.235-.374A9.86 9.86 0 012.106 12C2.106 6.58 6.58 2.106 12 2.106c5.419 0 9.894 4.474 9.894 9.894 0 5.419-4.475 9.894-9.894 9.894z"/></svg>
          Escribinos por WhatsApp
        </a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <div class="stat-num">48hs</div>
          <div class="stat-label">Entrega promedio</div>
        </div>
        <div class="stat-sep"></div>
        <div class="stat">
          <div class="stat-num">100%</div>
          <div class="stat-label">Satisfacción garantizada</div>
        </div>
        <div class="stat-sep"></div>
        <div class="stat">
          <div class="stat-num">$0</div>
          <div class="stat-label">Para empezar</div>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="browser-mock">
        <div class="browser-bar">
          <div class="browser-dots">
            <span style="background:#ff5f57"></span>
            <span style="background:#febc2e"></span>
            <span style="background:#28c840"></span>
          </div>
          <div class="browser-url">webripple.com/tu-negocio</div>
        </div>
        <div class="browser-content">
          <div class="mock-hero">
            <div class="mock-line w70 bold"></div>
            <div class="mock-line w50"></div>
            <div class="mock-line w40"></div>
            <div class="mock-btn"></div>
          </div>
          <div class="mock-cards">
            <div class="mock-card"><div class="mock-icon"></div><div class="mock-line w80"></div><div class="mock-line w60"></div></div>
            <div class="mock-card"><div class="mock-icon"></div><div class="mock-line w80"></div><div class="mock-line w60"></div></div>
            <div class="mock-card"><div class="mock-icon"></div><div class="mock-line w80"></div><div class="mock-line w60"></div></div>
          </div>
        </div>
      </div>
      <div class="floating-badge badge-speed">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0b7fcf" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        <span>Listo en 48hs</span>
      </div>
      <div class="floating-badge badge-check">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
        <span>100% responsive</span>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  min-height: 100vh;
  display: flex; align-items: center;
  position: relative; overflow: hidden;
  padding-top: 80px;
}
.hero-bg {
  position: absolute; inset: 0; z-index: 0;
}
.blob {
  position: absolute; border-radius: 50%;
  filter: blur(80px); opacity: 0.18;
}
.blob-1 {
  width: 600px; height: 600px;
  background: var(--blue);
  top: -200px; right: -100px;
  animation: blobFloat 8s ease-in-out infinite;
}
.blob-2 {
  width: 400px; height: 400px;
  background: var(--cyan);
  bottom: -100px; left: -100px;
  animation: blobFloat 10s ease-in-out infinite reverse;
}
.grid-overlay {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(11,127,207,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(11,127,207,0.04) 1px, transparent 1px);
  background-size: 48px 48px;
}
.hero-inner {
  max-width: 1200px; margin: 0 auto;
  padding: 80px 32px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  position: relative; z-index: 1;
  width: 100%;
}
.hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(41,198,224,0.1);
  border: 1px solid rgba(41,198,224,0.3);
  color: #0b7fcf;
  padding: 6px 14px;
  border-radius: 100px;
  font-size: 0.8rem; font-weight: 600;
  margin-bottom: 28px;
  width: fit-content;
}
.badge-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #29c6e0;
  animation: pulse 2s infinite;
}
.hero-title {
  font-family: 'Fraunces', serif;
  font-size: clamp(2.4rem, 4.5vw, 3.8rem);
  font-weight: 600;
  line-height: 1.1;
  color: var(--navy);
  margin-bottom: 24px;
  letter-spacing: -0.02em;
}
.hero-title em {
  font-style: italic;
  background: var(--grad);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero-desc {
  font-size: 1.05rem;
  line-height: 1.8;
  color: var(--muted);
  margin-bottom: 40px;
  max-width: 480px;
}
.hero-desc strong { color: var(--navy); font-weight: 600; }
.hero-actions { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 48px; }
.btn-primary {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--grad);
  color: white;
  padding: 14px 28px;
  border-radius: 12px;
  font-weight: 600; font-size: 0.95rem;
  transition: opacity 0.2s, transform 0.2s;
  box-shadow: 0 8px 24px rgba(11,127,207,0.3);
}
.btn-primary:hover { opacity: 0.9; transform: translateY(-2px); }
.btn-ghost {
  display: inline-flex; align-items: center; gap: 8px;
  border: 1.5px solid var(--border);
  color: var(--text);
  padding: 13px 24px;
  border-radius: 12px;
  font-weight: 600; font-size: 0.95rem;
  transition: border-color 0.2s, background 0.2s;
}
.btn-ghost:hover { border-color: var(--blue); background: var(--off); }
.hero-stats { display: flex; align-items: center; gap: 24px; }
.stat-num {
  font-family: 'Fraunces', serif;
  font-size: 1.8rem; font-weight: 600;
  color: var(--navy); line-height: 1;
}
.stat-label { font-size: 0.75rem; color: var(--muted); margin-top: 4px; }
.stat-sep { width: 1px; height: 36px; background: var(--border); }

/* BROWSER MOCKUP */
.hero-visual { position: relative; }
.browser-mock {
  background: white;
  border-radius: 16px;
  border: 1px solid var(--border);
  box-shadow: 0 32px 80px rgba(13,27,62,0.12), 0 4px 16px rgba(13,27,62,0.06);
  overflow: hidden;
}
.browser-bar {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 16px;
  background: var(--off);
  border-bottom: 1px solid var(--border);
}
.browser-dots { display: flex; gap: 6px; }
.browser-dots span { width: 10px; height: 10px; border-radius: 50%; }
.browser-url {
  flex: 1;
  background: white;
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 4px 12px;
  font-size: 0.72rem;
  color: var(--muted);
}
.browser-content { padding: 24px; }
.mock-hero {
  background: linear-gradient(135deg, #eef4ff 0%, #e8f9fc 100%);
  border-radius: 10px;
  padding: 28px 20px 20px;
  margin-bottom: 16px;
}
.mock-line {
  height: 10px; border-radius: 5px;
  background: rgba(13,27,62,0.12);
  margin-bottom: 10px;
}
.mock-line.bold { background: rgba(13,27,62,0.22); height: 14px; }
.mock-line.w70 { width: 70%; }
.mock-line.w50 { width: 50%; }
.mock-line.w40 { width: 40%; }
.mock-line.w60 { width: 60%; }
.mock-line.w80 { width: 80%; }
.mock-btn {
  width: 100px; height: 28px;
  border-radius: 6px;
  background: var(--grad);
  margin-top: 16px;
}
.mock-cards { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; }
.mock-card {
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 14px 12px;
}
.mock-icon {
  width: 28px; height: 28px;
  border-radius: 6px;
  background: linear-gradient(135deg, var(--blue), var(--cyan));
  margin-bottom: 10px; opacity: 0.7;
}

/* FLOATING BADGES */
.floating-badge {
  position: absolute;
  display: flex; align-items: center; gap: 8px;
  background: white;
  border: 1px solid var(--border);
  border-radius: 100px;
  padding: 8px 16px;
  font-size: 0.8rem; font-weight: 600;
  color: var(--text);
  box-shadow: 0 8px 24px rgba(13,27,62,0.1);
}
.badge-speed { top: -16px; right: -16px; }
.badge-check { bottom: 24px; left: -24px; }

@keyframes blobFloat {
  0%, 100% { transform: translate(0,0) scale(1); }
  50% { transform: translate(20px, -20px) scale(1.05); }
}
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(0.85); }
}

@media (max-width: 900px) {
  .hero-inner { grid-template-columns: 1fr; gap: 48px; text-align: center; }
  .hero-badge { margin: 0 auto 28px; }
  .hero-desc { margin: 0 auto 40px; }
  .hero-actions { justify-content: center; }
  .hero-stats { justify-content: center; }
  .badge-speed { top: -12px; right: 0; }
  .badge-check { bottom: 12px; left: 0; }
}
@media (max-width: 480px) {
  .hero-inner { padding: 48px 20px 60px; }
  .btn-primary, .btn-ghost { width: 100%; justify-content: center; }
  .mock-cards { grid-template-columns: repeat(3,1fr); }
}
</style>
