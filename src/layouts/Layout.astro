---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = "WebRipple — Páginas web profesionales en 48 horas",
  description = "Creamos landing pages y sitios web para emprendimientos y PyMEs argentinas. Diseño moderno, entrega rápida y precios accesibles.",
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Fraunces:ital,wght@0,300;0,600;1,300;1,600&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --navy:     #0d1b3e;
      --navy-mid: #162550;
      --blue:     #0b7fcf;
      --cyan:     #29c6e0;
      --white:    #ffffff;
      --off:      #f5f8ff;
      --text:     #1a2340;
      --muted:    #6b7a99;
      --border:   #e2e9f5;
      --grad:     linear-gradient(135deg, var(--blue) 0%, var(--cyan) 100%);
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      color: var(--text);
      background: var(--white);
      overflow-x: hidden;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
  </style>
</head>
<body>
  <slot />
</body>
</html>
